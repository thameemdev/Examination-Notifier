# Telegram Bot Settings
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# Execution configuration
# RUN_MODE: 'cron' (runs once and exits, suitable for GHA) or 'daemon' (continuous polling)
RUN_MODE=cron
CHECK_INTERVAL=10
LOG_LEVEL=INFO

# AI processing (Optional: Falls back to regex extraction if left empty)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
